---
import Icon from './Icons.astro';
import { getProjects } from '../lib/content-helpers';
import { Image } from 'astro:assets';
import myAccountImage from '../assets/myaccount.png';
import crocSpotImage from '../assets/croc-spot.png';
import tapestryImage from '../assets/tapestry.png';

const projects = await getProjects();

//To-Do: Fix this mapping for the images
const imageMap: Record<string, any> = {
  '../../assets/myaccount.png': myAccountImage,
  '../../assets/croc-spot.png': crocSpotImage,
  '../../assets/tapestry.png': tapestryImage,
};

// Replace string paths with actual image imports
const projectsWithImages = projects.map(project => ({
  ...project,
  data: {
    ...project.data,
    image: typeof project.data.image === 'string' && imageMap[project.data.image]
      ? imageMap[project.data.image]
      : project.data.image
  }
}));
---

<section id="projects" class="py-24 bg-dark-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-4xl sm:text-5xl font-bold text-white mb-16 text-center">Projects</h2>

    <div class="hidden md:grid grid-cols-3 gap-8 mb-12">
      {projectsWithImages.map((project) => (
        <div class="group overflow-hidden rounded-lg border border-dark-700 hover:border-primary-500 transition-all duration-300 hover:shadow-lg hover:shadow-primary-500/10 flex flex-col h-full bg-dark-800">
          <div class="relative overflow-hidden h-48">
            {typeof project.data.image === 'string' ? (
              <img
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
            ) : (
              <Image
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 400px"
              />
            )}
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-semibold text-white mb-2">{project.data.title}</h3>
            <p class="text-gray-400 text-sm mb-4 flex-grow">{project.data.description}</p>

            <div class="mb-4">
              <h4 class="text-white font-semibold text-sm mb-2">Highlights</h4>
              <ul class="space-y-1">
                {project.data.highlights.slice(0, 2).map((highlight) => (
                  <li class="flex items-start gap-2">
                    <span class="inline-block w-1 h-1 rounded-full bg-primary-400 mt-1 flex-shrink-0"></span>
                    <span class="text-gray-300 text-xs">{highlight}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="flex flex-wrap gap-2 mb-4">
              {project.data.technologies.slice(0, 3).map((tech) => (
                <span class="text-xs px-3 py-1 rounded-full bg-primary-900 text-primary-300">
                  {tech}
                </span>
              ))}
            </div>

            {project.data.link && (
              <a
                href={project.data.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-primary-400 hover:text-primary-300 transition-colors text-sm font-medium"
              >
                View Project
                <Icon name="externalLink" size={16} />
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="md:hidden">
      <div class="overflow-hidden pb-4" id="carousel-container">
        <div class="overflow-x-auto" id="carousel" style="scroll-snap-type: x mandatory; scroll-behavior: smooth;">
          <div class="flex gap-6 w-max px-[calc(50vw-160px)]" id="carousel-track">
            {projectsWithImages.map((project) => (
              <div class="flex-shrink-0 w-[85vw] group overflow-hidden rounded-lg border border-dark-700 hover:border-primary-500 transition-all duration-300 hover:shadow-lg hover:shadow-primary-500/10 flex flex-col bg-dark-800 scroll-snap-align-center" style="scroll-snap-align: center;">
                <div class="relative overflow-hidden h-48">
                  {typeof project.data.image === 'string' ? (
                    <img
                      src={project.data.image}
                      alt={project.data.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    />
                  ) : (
                    <Image
                      src={project.data.image}
                      alt={project.data.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      widths={[400, 800]}
                      sizes="(max-width: 768px) 100vw, 400px"
                    />
                  )}
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <h3 class="text-xl font-semibold text-white mb-2">{project.data.title}</h3>
                  <p class="text-gray-400 text-sm mb-4 flex-grow">{project.data.description}</p>

                  <div class="mb-4">
                    <h4 class="text-white font-semibold text-sm mb-2">Highlights</h4>
                    <ul class="space-y-1">
                      {project.data.highlights.slice(0, 2).map((highlight) => (
                        <li class="flex items-start gap-2">
                          <span class="inline-block w-1 h-1 rounded-full bg-primary-400 mt-1 flex-shrink-0"></span>
                          <span class="text-gray-300 text-xs">{highlight}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="flex flex-wrap gap-2 mb-4">
                    {project.data.technologies.slice(0, 3).map((tech) => (
                      <span class="text-xs px-3 py-1 rounded-full bg-primary-900 text-primary-300">
                        {tech}
                      </span>
                    ))}
                  </div>

                  {project.data.link && (
                    <a
                      href={project.data.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-primary-400 hover:text-primary-300 transition-colors text-sm font-medium"
                    >
                      View Project
                      <Icon name="externalLink" size={16} />
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="flex justify-center gap-4 mt-8">
        <button
          id="carousel-prev"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-dark-800 text-primary-400 hover:bg-primary-600 hover:text-white transition-all duration-300"
          aria-label="Previous project"
        >
          <Icon name="chevronLeft" size={20} />
        </button>
        <button
          id="carousel-next"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-dark-800 text-primary-400 hover:bg-primary-600 hover:text-white transition-all duration-300"
          aria-label="Next project"
        >
          <Icon name="chevronRight" size={20} />
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('carousel');
  const carouselTrack = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');

  if (carousel && carouselTrack && prevBtn && nextBtn) {
    const projectCount = carouselTrack.children.length;
    let currentIndex = 0;

    const getCardWidth = () => {
      const firstCard = carouselTrack.children[0] as HTMLElement;
      return firstCard ? firstCard.offsetWidth + 24 : 0; // card width + gap
    };

    const scrollToIndex = (index: number, smooth = true) => {
      const cardWidth = getCardWidth();
      const scrollPosition = index * cardWidth;
      carousel.scrollTo({
        left: scrollPosition,
        behavior: smooth ? 'smooth' : 'auto',
      });
    };

    prevBtn.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + projectCount) % projectCount;
      scrollToIndex(currentIndex);
    });

    nextBtn.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % projectCount;
      scrollToIndex(currentIndex);
    });

    // Handle manual scrolling to update currentIndex
    let scrollTimeout: number;
    carousel.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const scrollLeft = carousel.scrollLeft;
        const cardWidth = getCardWidth();
        currentIndex = Math.round(scrollLeft / cardWidth);
      }, 150);
    });

    // Initialize at the first card
    scrollToIndex(0, false);
  }
</script>
